# A2A Marketplace - Frontend Configuration
# Copy to .env.development (local) or .env.production (deploy)

# API server URL
REACT_APP_API_URL=http://localhost:3001

# reCAPTCHA v2 site key (https://www.google.com/recaptcha/admin)
# Leave empty to skip reCAPTCHA (registration won't work without it)
REACT_APP_RECAPTCHA_SITE_KEY=
