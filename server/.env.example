# ==================================
# A2A Task Marketplace - Server Config
# ==================================
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database (default: SQLite for development)
# For PostgreSQL, set both:
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/a2a

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# AI Provider API Keys (at least one required for AI features)
MOONSHOT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# reCAPTCHA v2 secret key (required for human user registration)
RECAPTCHA_SECRET=

# Admin API key (required for admin endpoints)
ADMIN_KEY=

# Rate limiting (default: enabled)
# RATE_LIMIT_ENABLED=true

# Stripe (optional, for payment integration)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
